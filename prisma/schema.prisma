generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// NICE Stage 1: Notes (Capture)
model Note {
  id            String   @id @default(uuid())
  rawInput      String
  inputType     String   // 'voice' | 'text' | 'quick_add'
  createdAt     DateTime @default(now())
  status        String   @default("captured") // 'captured' | 'investigated' | 'planned' | 'executing' | 'done' | 'archived'
  currentStage  String   @default("note") // 'note' | 'investigate' | 'create' | 'execute'

  investigation Investigation?

  @@index([status])
  @@index([currentStage])
}

// NICE Stage 2: Investigations (AI Processing)
model Investigation {
  id                  String   @id @default(uuid())
  noteId              String   @unique
  note                Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)

  aiInterpretation    String
  itemType            String   // 'task' | 'idea' | 'question' | 'reference' | 'problem'
  category            String   // 'money_move' | 'outreach' | 'build' | 'admin' | 'boredom' | 'someday'
  priority            String   // 'critical' | 'high' | 'medium' | 'low'
  complexity          String   // 'simple' | 'moderate' | 'complex'
  energyRequired      String   // 'high' | 'medium' | 'low'
  timeEstimateMinutes Int
  needsBreakdown      Boolean  @default(false)
  processedAt         DateTime @default(now())

  plans               Plan[]
}

// NICE Stage 3: Plans (Organization)
model Plan {
  id               String   @id @default(uuid())
  investigationId  String
  investigation    Investigation @relation(fields: [investigationId], references: [id], onDelete: Cascade)

  title            String
  description      String
  planType         String   // 'daily' | 'weekly' | 'project'
  scheduledDate    DateTime?
  scheduledTime    String?
  breakdownSteps   String?  // JSON array
  contextNotes     String?
  dependencies     String?  // JSON array of plan IDs
  createdAt        DateTime @default(now())

  execution        Execution?

  @@index([scheduledDate])
}

// NICE Stage 4: Executions (Doing)
model Execution {
  id                  String   @id @default(uuid())
  planId              String   @unique
  plan                Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)

  status              String   @default("not_started") // 'not_started' | 'in_progress' | 'completed' | 'blocked' | 'snoozed'
  startedAt           DateTime?
  completedAt         DateTime?
  timeSpentMinutes    Int      @default(0)
  blockerDescription  String?
  outcomeNotes        String?
  energyLevelActual   String?  // 'high' | 'medium' | 'low'

  @@index([status])
}

// Daily NICE Sessions (Track flow through stages)
model NiceSession {
  id                String   @id @default(uuid())
  date              DateTime @unique

  noteCount         Int      @default(0)
  investigateCount  Int      @default(0)
  createCount       Int      @default(0)
  executeCount      Int      @default(0)

  currentStage      String   @default("note")
  stageStartedAt    DateTime @default(now())
  sessionInsights   String?

  morningEnergyLevel String?
  eveningReflection  String?

  @@index([date])
}

// Pattern Recognition
model Pattern {
  id              String   @id @default(uuid())
  patternType     String   // 'procrastination' | 'energy' | 'productivity' | 'blocker'
  description     String
  observedCount   Int      @default(1)
  confidence      Float    @default(0.5)
  firstSeen       DateTime @default(now())
  lastSeen        DateTime @default(now())
  aiSuggestion    String?
  isActive        Boolean  @default(true)

  @@index([patternType])
  @@index([isActive])
}

// Wins (Positive reinforcement)
model Win {
  id          String   @id @default(uuid())
  description String
  category    String   // 'outreach' | 'demo' | 'proposal' | 'closed_deal' | 'learning' | 'consistency'
  impact      String   @default("medium") // 'small' | 'medium' | 'big'
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

// Coaching Conversations
model CoachingSession {
  id            String   @id @default(uuid())
  sessionType   String   // 'morning_plan' | 'stuck_support' | 'evening_review' | 'weekly_review' | 'general'
  conversation  String   // JSON array of messages
  insights      String?
  createdAt     DateTime @default(now())

  @@index([sessionType])
  @@index([createdAt])
}
