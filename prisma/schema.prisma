generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// WAVELENGTH AI - Auth & User Models
// ============================================

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  name             String?
  image            String?
  passwordHash     String?
  subscriptionTier String   @default("free") // 'free' | 'pro' | 'team'
  stripeCustomerId String?  @unique
  messagesThisMonth Int     @default(0)
  usageResetDate   DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  accounts      Account[]
  sessions      Session[]
  conversations Conversation[]
  teamMembers   TeamMember[]

  @@index([email])
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Team {
  id        String   @id @default(uuid())
  name      String
  ownerId   String
  createdAt DateTime @default(now())

  members TeamMember[]
}

model TeamMember {
  id     String @id @default(uuid())
  teamId String
  userId String
  role   String @default("member") // 'owner' | 'admin' | 'member'

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

// ============================================
// WAVELENGTH AI - Chat Models
// ============================================

model Conversation {
  id          String   @id @default(uuid())
  userId      String
  agentId     String
  title       String   @default("New Chat")
  isSwarm     Boolean  @default(false)
  swarmAgents String?  // JSON array of agent slugs
  model       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId])
  @@index([updatedAt])
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  role           String   // 'user' | 'assistant' | 'system'
  content        String
  agentId        String?
  model          String?
  tokenCount     Int      @default(0)
  metadata       String?  // JSON
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
}

// ============================================
// NICE Method Models (preserved from original)
// ============================================

model Note {
  id            String   @id @default(uuid())
  rawInput      String
  inputType     String
  createdAt     DateTime @default(now())
  status        String   @default("captured")
  currentStage  String   @default("note")

  investigation Investigation?

  @@index([status])
  @@index([currentStage])
}

model Investigation {
  id                  String   @id @default(uuid())
  noteId              String   @unique
  note                Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)

  aiInterpretation    String
  itemType            String
  category            String
  priority            String
  complexity          String
  energyRequired      String
  timeEstimateMinutes Int
  needsBreakdown      Boolean  @default(false)
  processedAt         DateTime @default(now())

  plans               Plan[]
}

model Plan {
  id               String   @id @default(uuid())
  investigationId  String
  investigation    Investigation @relation(fields: [investigationId], references: [id], onDelete: Cascade)

  title            String
  description      String
  planType         String
  scheduledDate    DateTime?
  scheduledTime    String?
  breakdownSteps   String?
  contextNotes     String?
  dependencies     String?
  createdAt        DateTime @default(now())

  execution        Execution?

  @@index([scheduledDate])
}

model Execution {
  id                  String   @id @default(uuid())
  planId              String   @unique
  plan                Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)

  status              String   @default("not_started")
  startedAt           DateTime?
  completedAt         DateTime?
  timeSpentMinutes    Int      @default(0)
  blockerDescription  String?
  outcomeNotes        String?
  energyLevelActual   String?

  @@index([status])
}

model NiceSession {
  id                String   @id @default(uuid())
  date              DateTime @unique

  noteCount         Int      @default(0)
  investigateCount  Int      @default(0)
  createCount       Int      @default(0)
  executeCount      Int      @default(0)

  currentStage      String   @default("note")
  stageStartedAt    DateTime @default(now())
  sessionInsights   String?

  morningEnergyLevel String?
  eveningReflection  String?

  @@index([date])
}

model Pattern {
  id              String   @id @default(uuid())
  patternType     String
  description     String
  observedCount   Int      @default(1)
  confidence      Float    @default(0.5)
  firstSeen       DateTime @default(now())
  lastSeen        DateTime @default(now())
  aiSuggestion    String?
  isActive        Boolean  @default(true)

  @@index([patternType])
  @@index([isActive])
}

model Win {
  id          String   @id @default(uuid())
  description String
  category    String
  impact      String   @default("medium")
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

model CoachingSession {
  id            String   @id @default(uuid())
  sessionType   String
  conversation  String
  insights      String?
  createdAt     DateTime @default(now())

  @@index([sessionType])
  @@index([createdAt])
}
